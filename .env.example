# Copy to .env next to compose.yml and fill in. Everything here is
# deployment-specific; the container-shaped path defaults live in the
# Dockerfile and compose.yml.

# The external Ollama instance (GPU VM). Must have the embedding model and —
# if OCR is enabled — the vision model pulled, and be >= the Ollama floor in
# ops/UPGRADING.md.
OLLAMA_BASE_URL=http://192.168.1.198:11434

# cloudflared tunnel token (Cloudflare Zero Trust dashboard -> Tunnels).
# Point the tunnel's ingress at http://mcp:3333.
TUNNEL_TOKEN=

# The public hostname the tunnel serves (e.g. mailvec.example.com). Required
# for tunnel traffic: the MCP server's DNS-rebinding HostGuard rejects any
# request whose Host header isn't loopback or allowlisted, and cloudflared
# forwards the original public Host. Leave empty until the tunnel goes live.
MCP_PUBLIC_HOSTNAME=

# The address LAN clients use to reach the MCP server directly (the Docker
# VM's IP or LAN hostname, e.g. 192.168.1.50) — needed for pre-tunnel testing
# or persistent on-network access, together with uncommenting the mcp
# service's ports: mapping in compose.yml. Same HostGuard rule as above.
MCP_LAN_HOSTNAME=

# Optional: Fastmail account id (the u<hex> query param in webmail URLs).
# Empty = search results omit webmailUrl links.
FASTMAIL_ACCOUNT_ID=

# Sync cadence for the mbsync sidecar. 600s matches the old launchd job; see
# the plist comment about .mbsyncstate lock contention before lowering it.
MBSYNC_INTERVAL_SECONDS=600

# 1 = services refuse to start if ./data/archive.sqlite is missing or empty
# (protects a snapshot-seeded deployment from silently serving a fresh empty
# archive after a bad volume mount). Set to 0 only for a deliberate
# from-scratch rebuild.
MAILVEC_REQUIRE_SEEDED_DB=1

# Deploy from prebuilt GHCR images instead of building on this host.
# Leave both unset to build locally (the default). To pull: set BOTH to a
# PINNED tag (sha-<gitsha> or v<version> — don't chase :latest; updates are
# manual + backup-first because SchemaMigrator runs against the seeded
# archive on every start), then `docker compose pull && docker compose up -d`.
# Never run `--build` while these point at the GHCR refs (it would retag the
# remote name with a local build). Private packages need a one-time
# `docker login ghcr.io` on this host (PAT with read:packages) — do that
# from the host CLI even if a UI like Dockge drives the pulls.
#MAILVEC_IMAGE=ghcr.io/djdelaney/mailvec:sha-xxxxxxx
#MAILVEC_MBSYNC_IMAGE=ghcr.io/djdelaney/mailvec-mbsync:sha-xxxxxxx
