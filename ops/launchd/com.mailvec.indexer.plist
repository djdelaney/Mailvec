<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mailvec.indexer</string>
    <key>ProgramArguments</key>
    <array>
        <string>__DOTNET__</string>
        <string>__INSTALL_PREFIX__/Mailvec.Indexer.dll</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__INSTALL_PREFIX__</string>
    <!-- Archive__DatabasePath and Ingest__MaildirRoot are surfaced as env vars
         (rather than left to the published appsettings.json) so a config
         change after install is a plist edit + reload, not a republish. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>MAILVEC_LAUNCHD</key>
        <string>1</string>
        <key>MAILVEC_LOG_DIR</key>
        <string>__LOG_DIR__</string>
        <key>Archive__DatabasePath</key>
        <string>__DB_PATH__</string>
        <key>Ingest__MaildirRoot</key>
        <string>__MAILDIR_ROOT__</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <!-- Serilog writes the rolling primary log to MAILVEC_LOG_DIR. These two
         paths only capture pre-Serilog startup output and unhandled native
         stderr (panics, runtime asserts). They grow slowly; no rotation needed. -->
    <key>StandardOutPath</key>
    <string>__LOG_DIR__/mailvec-indexer.launchd.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/mailvec-indexer.launchd.log</string>
</dict>
</plist>
