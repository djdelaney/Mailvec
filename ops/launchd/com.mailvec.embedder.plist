<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mailvec.embedder</string>
    <key>ProgramArguments</key>
    <array>
        <string>__DOTNET__</string>
        <string>__INSTALL_PREFIX__/Mailvec.Embedder.dll</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__INSTALL_PREFIX__</string>
    <!-- See com.mailvec.indexer.plist for the rationale on env-var overrides. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>MAILVEC_LAUNCHD</key>
        <string>1</string>
        <key>MAILVEC_LOG_DIR</key>
        <string>__LOG_DIR__</string>
        <key>Archive__DatabasePath</key>
        <string>__DB_PATH__</string>
        <key>Ollama__BaseUrl</key>
        <string>__OLLAMA_URL__</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <!-- See com.mailvec.indexer.plist for the rationale on these paths. -->
    <key>StandardOutPath</key>
    <string>__LOG_DIR__/mailvec-embedder.launchd.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/mailvec-embedder.launchd.log</string>
</dict>
</plist>
